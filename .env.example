# ============================================
# SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# BASE DE DATOS - SQL SERVER ERP (TECSOLED)
# Rellenar mañana con las credenciales reales
# ============================================
DB_SERVER=192.168.1.XXX        # IP del servidor SQL Server
DB_PORT=1433                    # Puerto por defecto de SQL Server
DB_NAME=nombre_bd_erp           # Nombre de la base de datos del ERP
DB_USER=usuario_lectura         # Usuario de solo lectura
DB_PASSWORD=contraseña_segura   # Contraseña del usuario
DB_ENCRYPT=false                # true si usas Azure, false para red local
DB_TRUST_CERT=true              # true para certificados autofirmados (red local)

# Pool de conexiones
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000

# ============================================
# BASE DE DATOS - SQL SERVER USUARIOS APP
# Base de datos propia para gestionar usuarios
# de la aplicación (separada del ERP)
# ============================================
DB_APP_SERVER=192.168.1.XXX
DB_APP_PORT=1433
DB_APP_NAME=tecsoled_app
DB_APP_USER=usuario_app
DB_APP_PASSWORD=contraseña_app

# ============================================
# JWT - AUTENTICACIÓN
# ============================================
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_minimo_32_caracteres
JWT_EXPIRES_IN=8h               # Sesión de 8 horas (jornada laboral)
JWT_REFRESH_EXPIRES_IN=24h

# ============================================
# SEGURIDAD
# ============================================
CORS_ORIGIN=http://localhost:5500   # Origen del frontend en desarrollo
RATE_LIMIT_WINDOW=15                # Minutos para rate limiting
RATE_LIMIT_MAX=100                  # Max requests por ventana
